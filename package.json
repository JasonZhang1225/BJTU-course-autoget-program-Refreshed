{
  "name": "web-get-course",
  "author": "hyskr",
  "version": "1.3.4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac --arm64"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-json-storage": "^4.6.0",
    "lodash": "^4.17.21",
    "tree-kill": "^1.2.2",
    "ws": "^8.18.0"
  },
  "build": {
    "productName": "北京交通大学自动选课软件",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "static/**/*",
      "src/login.py",
      "src/omis.onnx",
      "src/icon.ico",
      "src/icon.icns",
      "python/bjtupythonstub.py",
      "src/bjtupythonstub.exe",
      "src/bjtupythonstub-mac",
      "package.json",
      "!**/.DS_Store"
    ],
    "win": {
      "icon": "src/icon.ico",
      "artifactName": "Refreshed-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "icon": "src/icon.icns",
      "target": "dmg",
      "artifactName": "Refreshed-${version}-mac-${arch}.${ext}"
    },
    "asarUnpack": [
      "src/login.py",
      "src/omis.onnx",
      "python/bjtupythonstub.py",
      "src/bjtupythonstub.exe",
      "src/bjtupythonstub-mac"
    ]
  }
}
